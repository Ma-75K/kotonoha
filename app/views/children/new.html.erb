<div class= "container">
  <div class= "row">
    <div class= "col-md-10 col-lg-8 mx-auto">
      <h1 class="mb-4 text-center">お子さまの情報登録</h1>

      <div class="mb-5">
        <!-- ここにステップ1～2のアイコン入れる -->
      </div>

      <%= form_with model: @child, url: children_path, local: true do |f| %>

        <div class="mb-3">
          <%= f.label :name, class: "form-label" %>
          <%= f.text_field :name, class: "form-control" %>

          <% if @child.errors[:name].any? %>
            <div class="errors-message">
              <%= @child.errors.full_messages_for[:name].join(", ") %>
            </div>
          <% end %>
        </div>

        <div class="mb-3">
          <%= f.label :birthday, class: "form-label" %>
          <%= f.date_field :birthday, class: "form-control" %>

          <% if @child.errors[:birthday].any? %>
            <div class= "errors-message">
              <%= @child.errors.full_messages_for[:birthday].join(", ") %>
            </div>
          <% end %>
        </div>
        
        <div class="button-group">
          <%= f.submit "[ 登録完了 ]", class: "btn btn-primary" %>
          <%= link_to "[ 戻る ]", new_user_path, class: "btn btn-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
